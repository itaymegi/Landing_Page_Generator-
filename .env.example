# Active client — must match a key in `src/content/clients/registry.ts`
# Examples: godelivery | northline | example-cafe
VITE_CLIENT_ID=godelivery

# Page language: en (LTR) or he (RTL)
VITE_LOCALE=en

# Vercel lead delivery mode:
# - formspree_relay (temporary while no sender-domain DNS is available)
# - resend (future upgrade for branded sender)
LEAD_DELIVERY_MODE=formspree_relay

# Temporary relay endpoint used by `/api/lead` when LEAD_DELIVERY_MODE=formspree_relay.
FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Optional global prefix prepended by server endpoint to lead subject lines.
# LEAD_SUBJECT_PREFIX=[MegiWeb]

# Future upgrade (branded sending, optional for now):
# RESEND_API_KEY=re_xxx
# LEAD_FROM_EMAIL=leads@yourdomain.com
# LEAD_TO_EMAIL=owner@clientdomain.com
